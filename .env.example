# Секреты подключений. НЕ коммитить .env в git.
# Имена переменных: DATASAN_<DB>_<PARAM>

# Oracle
DATASAN_ORACLE_HOST=localhost
DATASAN_ORACLE_PORT=1521
DATASAN_ORACLE_SERVICE=ORCLPDB1
DATASAN_ORACLE_USER=datasan_user
DATASAN_ORACLE_PASSWORD=changeme
DATASAN_ORACLE_SCHEMA=DATASAN

# PostgreSQL
DATASAN_POSTGRES_HOST=localhost
DATASAN_POSTGRES_PORT=5432
DATASAN_POSTGRES_DATABASE=datasan
DATASAN_POSTGRES_USER=datasan_user
DATASAN_POSTGRES_PASSWORD=changeme
DATASAN_POSTGRES_SCHEMA=public

# MS SQL Server
DATASAN_MSSQL_HOST=localhost
DATASAN_MSSQL_PORT=1433
DATASAN_MSSQL_DATABASE=datasan
DATASAN_MSSQL_USER=datasan_user
DATASAN_MSSQL_PASSWORD=changeme
DATASAN_MSSQL_SCHEMA=dbo

# Лицензии DataSan (для SM-02/SM-03)
DATASAN_LICENSE_VALID=
DATASAN_LICENSE_INVALID=invalid-key-for-negative-tests
